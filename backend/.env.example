NODE_ENV=development
PORT=4010
HOST=127.0.0.1

# SQLite file. Use :memory: for tests.
DATABASE_URL=file:./freedom.sqlite

# Deployment registry JSON file or directory. If omitted, ../contracts/deployments is scanned.
FREEDOM_DEPLOYMENTS_PATH=../contracts/deployments

# Artifact root used for ABI loading.
FREEDOM_CONTRACTS_OUT=../contracts/out

# Optional polling indexer settings.
INDEXER_ENABLED=false
INDEXER_POLL_MS=12000
INDEXER_BLOCK_RANGE=2000

# Per-chain RPC URLs. The registry may also specify rpcUrl/rpcUrlEnv.
FREEDOM_31337_RPC_URL=http://127.0.0.1:8545

